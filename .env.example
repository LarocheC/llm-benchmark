# Copy to .env and fill in what you use:  cp .env.example .env
# The eval command is identical across providers — only --model and these env vars change.
# NOTE: Azure has FOUR distinct paths with different prefixes AND different base-URL suffixes.

# ── Default model (optional): lets you omit --model ──────────────────────────
# INSPECT_EVAL_MODEL=openai/azure/your-gpt-deployment

# ── Azure GPT (Azure OpenAI)  ->  --model openai/azure/<deployment> ──────────
#    Base URL has NO /models suffix.
AZUREAI_OPENAI_API_KEY=               # leave UNSET for keyless / Entra ID
AZUREAI_OPENAI_BASE_URL=https://YOUR-RESOURCE.openai.azure.com
AZUREAI_OPENAI_API_VERSION=2025-03-01-preview   # PIN this for reproducibility (default drifts)

# ── Azure Llama / Phi / generic Foundry  ->  --model azureai/<deployment> ────
#    Base URL ENDS IN /models. Needs azure-ai-inference (installed).
AZURE_API_KEY=                        # preferred key var for azureai/; leave UNSET for keyless
# AZUREAI_API_KEY=                    # fallback, used only if AZURE_API_KEY is unset
AZUREAI_BASE_URL=https://YOUR-RESOURCE.services.ai.azure.com/models

# ── Azure keyless (Entra ID / managed identity) ─────────────────────────────
#    Install azure-identity (done), run `az login` (or assign a managed identity),
#    and LEAVE the matching *_API_KEY unset.
AZUREAI_AUDIENCE=https://cognitiveservices.azure.com/.default   # optional; this is the default

# ── Azure Mistral / Claude (optional) ───────────────────────────────────────
#    Mistral -> mistral/azure/<deployment> ; Claude -> anthropic/azure/<deployment>
#    Both base URLs END IN /models. (Var spellings differ — see README "Gotchas".)
# AZUREAI_MISTRAL_API_KEY=
# AZUREAI_MISTRAL_BASE_URL=https://YOUR-RESOURCE.services.ai.azure.com/models

# ── Local: Ollama (already installed on this box)  ->  --model ollama/<model> ─
#    Start it with `ollama serve`, pull a model with `ollama pull llama3.1`.
OLLAMA_BASE_URL=http://localhost:11434/v1   # optional; this is the default

# ── Local: generic OpenAI-compatible server (vLLM/TGI/llama.cpp/LM Studio) ───
#    --model openai-api/local/<model>  reads <PREFIX>_BASE_URL / <PREFIX>_API_KEY
#    where PREFIX = the name segment, UPPERCASED ("local" -> LOCAL).
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_API_KEY=dummy-key

# ── Local: vLLM native provider (only if you `uv add vllm`)  ->  vllm/<hf-id> ─
# VLLM_BASE_URL=http://localhost:8000/v1   # set to attach to an already-running server
# VLLM_API_KEY=dummy-key
